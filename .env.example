# ==========================================
# PAGO CONFIGURATION
# ==========================================

# A secure password you create to protect invoice creation via the API
PAGO_API_KEY=

# Optional: CoinGecko API key for higher rate limits
COINGECKO_API_KEY=

# Only enable for testing, NEVER in production
ENABLE_MOCK_PAYMENTS=false

# ==========================================
# MONERO WALLET CONFIGURATION
# ==========================================

# The exact name of your wallet file located inside the ./data/wallet folder
WALLET_FILENAME=

# The password used to unlock your Monero wallet file
WALLET_PASSWORD=

# Define your own local or a remote Monero node (e.g node.sethforprivacy.com:443)
DAEMON_ADDRESS=

# The basic auth credentials for the internal RPC connection (Pago uses these to talk to the wallet)
RPC_USER=xmr
RPC_PASS=xmr
